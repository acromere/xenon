--verbose
--app-version "2.0"
--name "${project.name}"
--description "${project.description}"
--vendor "${project.organization.name}"
--copyright "Copyright ${project.inceptionYear} ${project.organization.name}"
--module "com.acromere.xenon"
--module-path "${jlink.module.path}"
--add-modules "jdk.crypto.mscapi"
--java-options "-Dprism.forceGPU=true --enable-native-access=javafx.graphics"
